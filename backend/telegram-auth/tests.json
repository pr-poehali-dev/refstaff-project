{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Unknown action returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "unknown"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Неизвестный action"},
      "bodyMatcher": "partial"
    },
    {
      "name": "send_register_code missing fields",
      "method": "POST",
      "path": "/",
      "body": {"action": "send_register_code"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Заполните все поля"},
      "bodyMatcher": "partial"
    },
    {
      "name": "send_login_code missing chat_id",
      "method": "POST",
      "path": "/",
      "body": {"action": "send_login_code"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Укажите Telegram Chat ID"},
      "bodyMatcher": "partial"
    }
  ]
}
